# Frontend environment variables
# Copy this file to .env.local and fill in real values.
# Never commit .env.local or any file containing real secrets.

VITE_TIKTOK_CLIENT_KEY=your_tiktok_client_key_here
VITE_TIKTOK_REDIRECT_URI=https://potucky.github.io/creatorflow-studio/

# ---------------------------------------------------------------------------
# Supabase Edge Function secrets
# Set these via: supabase secrets set KEY=value
# These are NOT frontend env vars — do not put them in .env.local.
# ---------------------------------------------------------------------------
# TIKTOK_CLIENT_SECRET=your_tiktok_client_secret_here
# TIKTOK_REDIRECT_URI=https://potucky.github.io/creatorflow-studio/
# ALLOWED_ORIGIN=https://potucky.github.io
# SUPABASE_URL=https://<your-project-ref>.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
# TIKTOK_ENV=sandbox
